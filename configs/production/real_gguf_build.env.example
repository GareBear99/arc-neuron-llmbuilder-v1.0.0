# Copy to real_gguf_build.env and edit all absolute paths.
FLAGSHIP_MODEL_NAME=cognition-core-flagship
FLAGSHIP_VERSION=1.0.0
MODEL_FAMILY=locked-upstream-family
PROMPT_PROFILE=flagship
MAX_CONTEXT_TOKENS=8192
COGNITION_CANDIDATE_ID=flagship_release
COGNITION_BASE_MODEL_DIR=/absolute/path/to/base_model_dir
COGNITION_MERGED_MODEL_DIR=/absolute/path/to/merged_model_dir
COGNITION_CONVERT_SCRIPT=/absolute/path/to/convert_to_gguf.py
COGNITION_CONVERT_EXTRA_ARGS=
COGNITION_QUANTIZE_BIN=/absolute/path/to/llama-quantize
COGNITION_RUNTIME_BINARY=/absolute/path/to/llama-cli
COGNITION_PYTHON_BIN=python3
COGNITION_QUANT_TYPE=Q4_K_M
COGNITION_FP16_MODEL_FILE=/absolute/path/to/output/cognition-core-flagship-f16.gguf
COGNITION_QUANTIZED_MODEL_FILE=/absolute/path/to/output/cognition-core-flagship-q4_k_m.gguf
# Optional: shell command that produces the merged model directory.
COGNITION_MERGE_COMMAND=
BUILD_LLAMAFILE=1
COGNITION_LLAMAFILE_BINARY=/absolute/path/to/llamafile
COGNITION_LLAMAFILE_FILE=/absolute/path/to/output/cognition-core-flagship.llamafile
