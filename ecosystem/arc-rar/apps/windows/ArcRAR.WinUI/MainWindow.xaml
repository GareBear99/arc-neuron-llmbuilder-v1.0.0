<Window
    x:Class="ArcRAR.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Arc-RAR">
    <StackPanel Spacing="12" Padding="16">
        <TextBlock Text="Arc-RAR" FontSize="28" FontWeight="Bold" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Open Sample" Click="OpenSample_Click" />
            <Button Content="Refresh Status" Click="RefreshStatus_Click" />
        </StackPanel>
        <TextBox x:Name="OutputBox" AcceptsReturn="True" Height="320" TextWrapping="Wrap" />
    </StackPanel>
</Window>
