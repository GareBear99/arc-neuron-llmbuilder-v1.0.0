{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactManifestV1",
  "type": "object",
  "required": ["artifact_id", "stage", "candidate", "status", "created_at", "paths"],
  "properties": {
    "artifact_id": {"type": "string"},
    "stage": {"type": "string"},
    "candidate": {"type": "string"},
    "status": {"type": "string"},
    "created_at": {"type": "string"},
    "config": {"type": ["string", "null"]},
    "base_model": {"type": ["string", "null"]},
    "notes": {"type": ["string", "null"]},
    "paths": {
      "type": "object",
      "additionalProperties": {"type": ["string", "array", "object", "null"]}
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "source_manifest": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
