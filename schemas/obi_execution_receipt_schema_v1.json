{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obi_execution_receipt_v1",
  "type": "object",
  "required": [
    "artifact",
    "classification",
    "lane_decision",
    "mode",
    "blockers",
    "evidence_summary"
  ],
  "properties": {
    "artifact": {
      "type": "string"
    },
    "classification": {
      "type": "string"
    },
    "lane_decision": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "preview",
        "preflight",
        "execute"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_summary": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}